{
  "Qwik Component": {
    "prefix": "qwik-component",
    "description": "Basic Qwik component using component$()",
    "body": [
      "import { component\\$ } from '@builder.io/qwik';",
      "",
      "export const ${1:MyComponent} = component\\$(() => {",
      "  return (",
      "    <div>",
      "      ${2:content}",
      "    </div>",
      "  );",
      "});"
    ]
  },
  "Qwik Component with Props": {
    "prefix": "qwik-component-props",
    "description": "Qwik component with typed props",
    "body": [
      "import { component\\$ } from '@builder.io/qwik';",
      "",
      "interface ${1:MyComponent}Props {",
      "  ${2:prop}: ${3:string};",
      "}",
      "",
      "export default component\\$<$1Props>(({ $2 }) => {",
      "  return (",
      "    <div>",
      "      {$2}",
      "    </div>",
      "  );",
      "});"
    ]
  },
  "Qwik useSignal": {
    "prefix": "qwik-signal",
    "description": "useSignal() — reactive signal",
    "body": [
      "const ${1:count} = useSignal(${2:0});"
    ]
  },
  "Qwik useStore": {
    "prefix": "qwik-store",
    "description": "useStore() — reactive store object",
    "body": [
      "const ${1:store} = useStore({",
      "  ${2:key}: ${3:value},",
      "});"
    ]
  },
  "Qwik useTask": {
    "prefix": "qwik-useTask",
    "description": "useTask$() — runs on server or browser, re-runs on tracked changes",
    "body": [
      "useTask\\$(({ track, cleanup }) => {",
      "  track(() => ${1:signal.value});",
      "  ${2:// task logic}",
      "  cleanup(() => {",
      "    ${3:// cleanup}",
      "  });",
      "});"
    ]
  },
  "Qwik useVisibleTask": {
    "prefix": "qwik-useVisibleTask",
    "description": "useVisibleTask$() — browser-only, runs after render",
    "body": [
      "useVisibleTask\\$(({ cleanup }) => {",
      "  ${1:// browser-only code}",
      "  cleanup(() => {",
      "    ${2:// cleanup}",
      "  });",
      "});"
    ]
  },
  "Qwik useResource": {
    "prefix": "qwik-resource",
    "description": "useResource$() — async data fetching",
    "body": [
      "const ${1:data} = useResource\\$<${2:Type}>(async ({ track, cleanup }) => {",
      "  track(() => ${3:signal.value});",
      "  const controller = new AbortController();",
      "  cleanup(() => controller.abort());",
      "  return ${4:fetchData}();",
      "});"
    ]
  },
  "Qwik onClick": {
    "prefix": "qwik-onClick",
    "description": "onClick$ event handler",
    "body": [
      "onClick\\$={() => {",
      "  ${1:// handler}",
      "}}"
    ]
  },
  "Qwik onInput": {
    "prefix": "qwik-onInput",
    "description": "onInput$ event handler",
    "body": [
      "onInput\\$={(e) => {",
      "  ${1:store.value} = (e.target as HTMLInputElement).value;",
      "}}"
    ]
  },
  "Qwik preventDefault": {
    "prefix": "qwik-preventdefault",
    "description": "Prevent default click — no JS needed",
    "body": [
      "preventdefault:click"
    ]
  },
  "Qwik createContextId": {
    "prefix": "qwik-createContext",
    "description": "createContextId() — define a context",
    "body": [
      "export const ${1:MyContext} = createContextId<${2:Type}>('${3:my-context}');"
    ]
  },
  "Qwik useContextProvider": {
    "prefix": "qwik-useContextProvider",
    "description": "useContextProvider() — provide context to children",
    "body": [
      "useContextProvider(${1:MyContext}, ${2:value});"
    ]
  },
  "Qwik useContext": {
    "prefix": "qwik-useContext",
    "description": "useContext() — consume context",
    "body": [
      "const ${1:value} = useContext(${2:MyContext});"
    ]
  },
  "Qwik Slot": {
    "prefix": "qwik-slot",
    "description": "Default Slot for content projection",
    "body": [
      "<Slot />"
    ]
  },
  "Qwik Named Slot": {
    "prefix": "qwik-slot-named",
    "description": "Named Slot for content projection",
    "body": [
      "<Slot name=\"${1:slotName}\" />"
    ]
  },
  "Qwik useStyles": {
    "prefix": "qwik-useStyles",
    "description": "useStyles$() — load component styles",
    "body": [
      "import styles from './${1:component}.css?inline';",
      "useStyles\\$(styles);"
    ]
  },
  "Qwik useStylesScoped": {
    "prefix": "qwik-useStylesScoped",
    "description": "useStylesScoped$() — scoped component styles",
    "body": [
      "import styles from './${1:component}.css?inline';",
      "useStylesScoped\\$(styles);"
    ]
  },
  "Qwik City Layout": {
    "prefix": "qwik-layout",
    "description": "Qwik City layout component",
    "body": [
      "import { component\\$, Slot } from '@builder.io/qwik';",
      "",
      "export default component\\$(() => {",
      "  return (",
      "    <>",
      "      <header>${1:Header}</header>",
      "      <main>",
      "        <Slot />",
      "      </main>",
      "      <footer>${2:Footer}</footer>",
      "    </>",
      "  );",
      "});"
    ]
  },
  "Qwik City Page": {
    "prefix": "qwik-page",
    "description": "Qwik City page with DocumentHead",
    "body": [
      "import { component\\$ } from '@builder.io/qwik';",
      "import type { DocumentHead } from '@builder.io/qwik-city';",
      "",
      "export default component\\$(() => {",
      "  return (",
      "    <div>",
      "      <h1>${1:Page Title}</h1>",
      "    </div>",
      "  );",
      "});",
      "",
      "export const head: DocumentHead = {",
      "  title: '${2:Page Title}',",
      "  meta: [",
      "    { name: 'description', content: '${3:Page description}' },",
      "  ],",
      "};"
    ]
  },
  "Qwik City routeLoader": {
    "prefix": "qwik-loader",
    "description": "routeLoader$() — server-side data loader",
    "body": [
      "import { routeLoader\\$ } from '@builder.io/qwik-city';",
      "",
      "export const ${1:useData} = routeLoader\\$(async ({ params }) => {",
      "  return {",
      "    ${2:key}: ${3:value},",
      "  };",
      "});"
    ]
  },
  "Qwik City routeAction": {
    "prefix": "qwik-action",
    "description": "routeAction$() — form action with Zod validation",
    "body": [
      "import { routeAction\\$, zod\\$, z } from '@builder.io/qwik-city';",
      "",
      "export const ${1:useAction} = routeAction\\$(",
      "  async (data, { redirect }) => {",
      "    ${2:// handle action}",
      "    throw redirect(302, '${3:/}');",
      "  },",
      "  zod\\$({",
      "    ${4:field}: z.string(),",
      "  })",
      ");"
    ]
  },
  "Qwik City useLocation": {
    "prefix": "qwik-useLocation",
    "description": "useLocation() — access URL, params, and query",
    "body": [
      "const loc = useLocation();"
    ]
  },
  "Qwik City Link": {
    "prefix": "qwik-link",
    "description": "Qwik City Link component",
    "body": [
      "<Link href=\"${1:/path}\">${2:label}</Link>"
    ]
  },
  "Qwik City Static Head": {
    "prefix": "qwik-static-head",
    "description": "Static DocumentHead export",
    "body": [
      "export const head: DocumentHead = {",
      "  title: '${1:Page Title}',",
      "  meta: [",
      "    { name: 'description', content: '${2:Description}' },",
      "  ],",
      "};"
    ]
  },
  "Qwik City Dynamic Head": {
    "prefix": "qwik-dynamic-head",
    "description": "Dynamic DocumentHead using routeLoader data",
    "body": [
      "export const head: DocumentHead = ({ resolveValue }) => {",
      "  const ${1:data} = resolveValue(${2:useData});",
      "  return {",
      "    title: `${1:data}.${3:title}`,",
      "    meta: [",
      "      { name: 'description', content: `${1:data}.${4:description}` },",
      "    ],",
      "  };",
      "};"
    ]
  },
  "Qwik City onGet": {
    "prefix": "qwik-onGet",
    "description": "onGet API route handler",
    "body": [
      "import type { RequestHandler } from '@builder.io/qwik-city';",
      "",
      "export const onGet: RequestHandler = async ({ json }) => {",
      "  json(200, { ${1:key}: '${2:value}' });",
      "};"
    ]
  },
  "Qwik City onPost": {
    "prefix": "qwik-onPost",
    "description": "onPost API route handler",
    "body": [
      "import type { RequestHandler } from '@builder.io/qwik-city';",
      "",
      "export const onPost: RequestHandler = async ({ request, json }) => {",
      "  const body = await request.json();",
      "  json(200, { ${1:key}: '${2:value}' });",
      "};"
    ]
  }
}